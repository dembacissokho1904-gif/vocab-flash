    function markCard(gotIt) {
      const card = cards[currentIndex];
      if (gotIt) {
        mastered.add(card.id);
        stillLearning.delete(card.id);
        showToast(`✓ "${card.es}" mastered!`);
      } else {
        stillLearning.add(card.id);
        mastered.delete(card.id);
        showToast(`↻ "${card.es}" — keep practicing!`);
      }
      updateProgress();
      renderMasteryBars();

      if (mastered.size === cards.length) {
        setTimeout(() => showComplete(), 500);
        return;
      }

      // Go to next unmastered card
      let next = (currentIndex + 1) % cards.length;
      let attempts = 0;
      while (mastered.has(cards[next].id) && attempts < cards.length) {
        next = (next + 1) % cards.length;
        attempts++;
      }
      currentIndex = next;
      loadCard(currentIndex);
    }

    function updateProgress() {
      const ring = document.getElementById('progress-ring');
      const circumference = 326.73;
      const pct = mastered.size / cards.length;
      ring.style.strokeDashoffset = circumference * (1 - pct);
      document.getElementById('progress-count').textContent = `${mastered.size}/${cards.length}`;
    }

