              <div class="mastery-bar h-full rounded-full" style="width: ${barWidth}; background: ${barColor};"></div>
            </div>
            <span class="text-xs w-4 text-center" style="color: ${secondary};">${statusLabel}</span>
          `;
          container.appendChild(row);
        } else {
          const bar = row.querySelector('.mastery-bar');
          bar.style.width = barWidth;
          bar.style.background = barColor;
          const label = row.querySelector('span:last-child');
          label.textContent = statusLabel;
          // Update colors
          row.querySelector('span:first-child').style.color = secondary;
          row.querySelector('.mastery-bar').parentElement.style.background = lighten(surface, 8);
          label.style.color = secondary;
