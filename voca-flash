      const config = window.elementSdk.config || {};
      const primary = config.primary_color || defaultConfig.primary_color;
      const secondary = config.secondary_color || defaultConfig.secondary_color;
      const text = config.text_color || defaultConfig.text_color;
      const surface = config.surface_color || defaultConfig.surface_color;

      // Build or update bars
      cards.forEach((card, i) => {
        let row = container.querySelector(`[data-card-id="${card.id}"]`);
        const isMastered = mastered.has(card.id);
        const isLearning = stillLearning.has(card.id);
        const status = isMastered ? 'mastered' : isLearning ? 'learning' : 'new';
        const barWidth = isMastered ? '100%' : isLearning ? '40%' : '0%';
        const barColor = isMastered ? '#22c55e' : isLearning ? '#f59e0b' : 'transparent';
        const statusLabel = isMastered ? '✓' : isLearning ? '…' : '';

        if (!row) {
          row = document.createElement('div');
          row.dataset.cardId = card.id;
          row.className = 'flex items-center gap-3';
